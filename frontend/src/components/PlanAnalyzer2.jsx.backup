import { useState } from 'react';
import { Upload, Trash2, FileText, Loader2, CheckCircle, AlertCircle, ArrowRight, List } from 'lucide-react';
import { useAuth } from '../context/AuthContext';
import { useAppNavigate } from '../hooks/useAppNavigate';
import { authFetch } from '../utils/authFetch';
import * as pdfjsLib from 'pdfjs-dist';

// 配置 PDF.js worker
pdfjsLib.GlobalWorkerOptions.workerSrc = `https://unpkg.com/pdfjs-dist@${pdfjsLib.version}/build/pdf.worker.min.mjs`;

const API_BASE_URL = '';

function PlanAnalyzer2() {
  const onNavigate = useAppNavigate();
  const { user } = useAuth();

  // 三个PDF文件的状态
  const [files, setFiles] = useState([
    { id: 1, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' },
    { id: 2, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' },
    { id: 3, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' }
  ]);

  const [isAnalyzing, setIsAnalyzing] = useState(false);
  const [comparisonId, setComparisonId] = useState(null);
  const [comparisonStatus, setComparisonStatus] = useState('');
  const [comparisonResult, setComparisonResult] = useState(null);
  const [showResult, setShowResult] = useState(false);

  // 快速检测PDF是否包含表格元素
  const detectTableInPDF = async (file) => {
    try {
      console.log('🔍 开始检测PDF表格...');
      const arrayBuffer = await file.arrayBuffer();
      const pdf = await pdfjsLib.getDocument({ data: arrayBuffer }).promise;
      const pagesToCheck = Math.min(pdf.numPages, 6);

      for (let pageNum = 1; pageNum <= pagesToCheck; pageNum++) {
        const page = await pdf.getPage(pageNum);
        const textContent = await page.getTextContent();
        const pageText = textContent.items.map(item => item.str).join(' ');

        const hasTableMarkers = /<table|<tr|<td/i.test(pageText);
        const hasTableKeywords = /年度|保单年度|退保金|现金价值|保险金额|累计|表格/i.test(pageText);
        const digitCount = (pageText.match(/\d/g) || []).length;
        const textLength = pageText.length;
        const digitRatio = textLength > 0 ? digitCount / textLength : 0;

        if (hasTableMarkers || (hasTableKeywords && digitRatio > 0.15)) {
          console.log(\`✅ 在第\${pageNum}页检测到表格元素\`);
          return true;
        }
      }

      console.log('❌ 未检测到表格元素');
      return false;
    } catch (error) {
      console.error('PDF检测出错:', error);
      return true; // 出错时允许继续处理
    }
  };

  // 处理文件选择
  const handleFileSelect = async (slotId, e) => {
    const file = e.target.files?.[0];
    if (!file) return;

    // 检查文件类型
    if (file.type !== 'application/pdf') {
      alert('请上传PDF文件');
      return;
    }

    // 检查文件大小（最大50MB）
    if (file.size > 50 * 1024 * 1024) {
      alert('文件大小不能超过50MB');
      return;
    }

    // 检测是否包含表格
    const hasTable = await detectTableInPDF(file);
    if (!hasTable) {
      const confirmUpload = window.confirm(
        '⚠️ 警告：未检测到保单年度价值表\n\n' +
        '该PDF似乎不包含保险计划书的年度价值表格。\n' +
        '分析结果可能不完整。\n\n' +
        '是否仍要上传此文件？'
      );
      if (!confirmUpload) {
        return;
      }
    }

    // 更新文件状态
    setFiles(prev => prev.map(f =>
      f.id === slotId
        ? { ...f, file, fileName: file.name, status: 'selected' }
        : f
    ));
  };

  // 移除文件
  const handleRemoveFile = (slotId) => {
    setFiles(prev => prev.map(f =>
      f.id === slotId
        ? { id: f.id, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' }
        : f
    ));
  };

  // 上传并分析单个文件
  const uploadAndAnalyzeFile = async (slotId) => {
    const fileSlot = files.find(f => f.id === slotId);
    if (!fileSlot || !fileSlot.file) return null;

    try {
      // 更新状态为上传中
      setFiles(prev => prev.map(f =>
        f.id === slotId ? { ...f, status: 'uploading', progress: 10 } : f
      ));

      const formData = new FormData();
      formData.append('file', fileSlot.file);

      const response = await authFetch(\`\${API_BASE_URL}/api/ocr/upload-async/\`, {
        method: 'POST',
        body: formData,
      });

      if (!response.ok) {
        throw new Error('上传失败');
      }

      const data = await response.json();
      const documentId = data.document_id;

      // 更新状态为分析中
      setFiles(prev => prev.map(f =>
        f.id === slotId ? { ...f, documentId, status: 'analyzing', progress: 30 } : f
      ));

      // 轮询检查分析状态
      return await pollDocumentStatus(slotId, documentId);

    } catch (error) {
      console.error(\`文件\${slotId}上传失败:\`, error);
      setFiles(prev => prev.map(f =>
        f.id === slotId ? { ...f, status: 'error', error: error.message } : f
      ));
      return null;
    }
  };

  // 轮询文档分析状态
  const pollDocumentStatus = async (slotId, documentId) => {
    const maxAttempts = 60; // 最多轮询60次（5分钟）
    let attempts = 0;

    const checkStatus = async () => {
      try {
        const response = await authFetch(\`\${API_BASE_URL}/api/ocr/documents/\${documentId}/status/\`);
        const data = await response.json();

        const progressMap = {
          'ocr_processing': 40,
          'ocr_completed': 50,
          'extracting_table1': 60,
          'extracting_basic_info': 70,
          'all_completed': 100
        };

        const progress = progressMap[data.processing_stage] || 30;

        setFiles(prev => prev.map(f =>
          f.id === slotId ? { ...f, progress } : f
        ));

        if (data.status === 'completed') {
          setFiles(prev => prev.map(f =>
            f.id === slotId ? { ...f, status: 'completed', progress: 100 } : f
          ));
          return documentId;
        }

        if (data.status === 'failed') {
          throw new Error(data.error_message || '分析失败');
        }

        // 继续轮询
        attempts++;
        if (attempts < maxAttempts) {
          await new Promise(resolve => setTimeout(resolve, 5000)); // 5秒间隔
          return checkStatus();
        } else {
          throw new Error('分析超时');
        }

      } catch (error) {
        console.error(\`文件\${slotId}状态检查失败:\`, error);
        setFiles(prev => prev.map(f =>
          f.id === slotId ? { ...f, status: 'error', error: error.message } : f
        ));
        return null;
      }
    };

    return checkStatus();
  };

  // 开始批量分析
  const handleStartAnalysis = async () => {
    // 检查至少有2个文件
    const selectedFiles = files.filter(f => f.file !== null);
    if (selectedFiles.length < 2) {
      alert('请至少上传2份PDF计划书');
      return;
    }

    setIsAnalyzing(true);

    try {
      // 并行上传和分析所有文件
      const uploadPromises = selectedFiles.map(f => uploadAndAnalyzeFile(f.id));
      const documentIds = await Promise.all(uploadPromises);

      // 过滤掉失败的文档
      const validDocumentIds = documentIds.filter(id => id !== null);

      if (validDocumentIds.length < 2) {
        alert('至少需要2份计划书分析成功才能进行对比');
        setIsAnalyzing(false);
        return;
      }

      // 调用对比分析API
      await createComparison(validDocumentIds);

    } catch (error) {
      console.error('批量分析失败:', error);
      alert('分析过程出错，请重试');
    } finally {
      setIsAnalyzing(false);
    }
  };

  // 创建对比分析
  const createComparison = async (documentIds) => {
    try {
      setComparisonStatus('generating');

      const response = await authFetch(\`\${API_BASE_URL}/api/comparison/create_comparison/\`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          document_ids: documentIds,
          title: \`\${documentIds.length}份计划书对比分析\`
        })
      });

      if (!response.ok) {
        const errorData = await response.json();
        throw new Error(errorData.error || '创建对比分析失败');
      }

      const data = await response.json();
      setComparisonId(data.id);
      setComparisonResult(data);
      setComparisonStatus('completed');
      setShowResult(true);

    } catch (error) {
      console.error('创建对比分析失败:', error);
      setComparisonStatus('error');
      alert(error.message);
    }
  };

  // 重置所有状态
  const handleReset = () => {
    setFiles([
      { id: 1, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' },
      { id: 2, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' },
      { id: 3, file: null, fileName: '', documentId: null, status: 'empty', progress: 0, error: '' }
    ]);
    setIsAnalyzing(false);
    setComparisonId(null);
    setComparisonStatus('');
    setComparisonResult(null);
    setShowResult(false);
  };

  // 渲染单个文件上传卡片
  const renderFileCard = (fileSlot) => {
    const statusIcons = {
      empty: <Upload className="w-12 h-12 text-gray-400" />,
      selected: <FileText className="w-12 h-12 text-blue-500" />,
      uploading: <Loader2 className="w-12 h-12 text-blue-500 animate-spin" />,
      analyzing: <Loader2 className="w-12 h-12 text-purple-500 animate-spin" />,
      completed: <CheckCircle className="w-12 h-12 text-green-500" />,
      error: <AlertCircle className="w-12 h-12 text-red-500" />
    };

    const statusTexts = {
      empty: '点击上传PDF',
      selected: '已选择',
      uploading: '上传中...',
      analyzing: '分析中...',
      completed: '分析完成',
      error: '分析失败'
    };

    return (
      <div key={fileSlot.id} className="bg-white rounded-lg shadow-md p-6 border-2 border-dashed border-gray-300 hover:border-blue-400 transition-colors">
        <div className="text-center">
          {/* 文件图标 */}
          <div className="flex justify-center mb-4">
            {statusIcons[fileSlot.status]}
          </div>

          {/* 标题 */}
          <h3 className="text-lg font-semibold mb-2">计划书 {fileSlot.id}</h3>

          {/* 文件名 */}
          {fileSlot.fileName && (
            <p className="text-sm text-gray-600 mb-2 truncate" title={fileSlot.fileName}>
              {fileSlot.fileName}
            </p>
          )}

          {/* 状态文本 */}
          <p className="text-sm text-gray-500 mb-4">{statusTexts[fileSlot.status]}</p>

          {/* 进度条 */}
          {(fileSlot.status === 'uploading' || fileSlot.status === 'analyzing') && (
            <div className="w-full bg-gray-200 rounded-full h-2 mb-4">
              <div
                className="bg-blue-500 h-2 rounded-full transition-all duration-300"
                style={{ width: \`\${fileSlot.progress}%\` }}
              />
            </div>
          )}

          {/* 错误信息 */}
          {fileSlot.status === 'error' && (
            <p className="text-xs text-red-500 mb-4">{fileSlot.error}</p>
          )}

          {/* 操作按钮 */}
          {fileSlot.status === 'empty' && (
            <label className="cursor-pointer">
              <input
                type="file"
                accept="application/pdf"
                onChange={(e) => handleFileSelect(fileSlot.id, e)}
                className="hidden"
              />
              <div className="bg-blue-500 text-white px-4 py-2 rounded-lg hover:bg-blue-600 inline-block">
                选择文件
              </div>
            </label>
          )}

          {(fileSlot.status === 'selected' || fileSlot.status === 'error') && (
            <button
              onClick={() => handleRemoveFile(fileSlot.id)}
              className="bg-red-500 text-white px-4 py-2 rounded-lg hover:bg-red-600 flex items-center gap-2 mx-auto"
            >
              <Trash2 className="w-4 h-4" />
              移除文件
            </button>
          )}
        </div>
      </div>
    );
  };

  return (
    <div className="min-h-screen bg-gradient-to-br from-blue-50 via-purple-50 to-pink-50 p-6">
      <div className="max-w-7xl mx-auto">
        {/* 顶部导航 */}
        <div className="flex justify-between items-center mb-8">
          <div>
            <h1 className="text-3xl font-bold text-gray-800 mb-2">多计划书对比分析</h1>
            <p className="text-gray-600">同时上传2-3份保险计划书，AI智能对比分析</p>
          </div>
          <div className="flex gap-3">
            <button
              onClick={() => onNavigate('/comparison-history')}
              className="flex items-center gap-2 px-4 py-2 bg-purple-500 text-white rounded-lg hover:bg-purple-600 transition-colors"
            >
              <List className="w-5 h-5" />
              对比历史
            </button>
            <button
              onClick={() => onNavigate('/dashboard')}
              className="px-4 py-2 bg-gray-500 text-white rounded-lg hover:bg-gray-600 transition-colors"
            >
              返回首页
            </button>
          </div>
        </div>

        {!showResult ? (
          <>
            {/* 文件上传区域 */}
            <div className="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
              {files.map(fileSlot => renderFileCard(fileSlot))}
            </div>

            {/* 分析按钮 */}
            <div className="text-center">
              <button
                onClick={handleStartAnalysis}
                disabled={isAnalyzing || files.filter(f => f.file !== null).length < 2}
                className={\`
                  px-8 py-4 rounded-lg text-lg font-semibold flex items-center gap-3 mx-auto
                  \${isAnalyzing || files.filter(f => f.file !== null).length < 2
                    ? 'bg-gray-300 text-gray-500 cursor-not-allowed'
                    : 'bg-gradient-to-r from-blue-500 to-purple-500 text-white hover:from-blue-600 hover:to-purple-600'
                  }
                \`}
              >
                {isAnalyzing ? (
                  <>
                    <Loader2 className="w-6 h-6 animate-spin" />
                    正在分析中...
                  </>
                ) : (
                  <>
                    <ArrowRight className="w-6 h-6" />
                    开始对比分析
                  </>
                )}
              </button>
              <p className="text-sm text-gray-500 mt-4">
                请至少上传2份计划书，最多3份
              </p>
            </div>

            {/* 对比生成进度 */}
            {comparisonStatus === 'generating' && (
              <div className="mt-8 bg-white rounded-lg shadow-md p-6">
                <div className="flex items-center gap-4">
                  <Loader2 className="w-8 h-8 text-blue-500 animate-spin" />
                  <div>
                    <h3 className="text-lg font-semibold text-gray-800">正在生成对比报告</h3>
                    <p className="text-sm text-gray-600">AI正在深度分析各份计划书的差异...</p>
                  </div>
                </div>
              </div>
            )}
          </>
        ) : (
          /* 对比结果展示 */
          <div className="bg-white rounded-lg shadow-md p-8">
            <div className="flex justify-between items-center mb-6">
              <h2 className="text-2xl font-bold text-gray-800">对比分析报告</h2>
              <button
                onClick={handleReset}
                className="px-4 py-2 bg-blue-500 text-white rounded-lg hover:bg-blue-600"
              >
                新建对比
              </button>
            </div>

            {/* 对比的计划书列表 */}
            <div className="mb-6">
              <h3 className="text-lg font-semibold mb-3">对比计划书</h3>
              <div className="grid grid-cols-1 md:grid-cols-3 gap-4">
                {comparisonResult?.document1_detail && (
                  <div className="bg-blue-50 p-4 rounded-lg">
                    <h4 className="font-semibold text-blue-700 mb-2">计划书 1</h4>
                    <p className="text-sm text-gray-700">{comparisonResult.document1_detail.file_name}</p>
                    <p className="text-xs text-gray-600 mt-1">
                      {comparisonResult.document1_detail.insurance_company} - {comparisonResult.document1_detail.insurance_product}
                    </p>
                  </div>
                )}
                {comparisonResult?.document2_detail && (
                  <div className="bg-purple-50 p-4 rounded-lg">
                    <h4 className="font-semibold text-purple-700 mb-2">计划书 2</h4>
                    <p className="text-sm text-gray-700">{comparisonResult.document2_detail.file_name}</p>
                    <p className="text-xs text-gray-600 mt-1">
                      {comparisonResult.document2_detail.insurance_company} - {comparisonResult.document2_detail.insurance_product}
                    </p>
                  </div>
                )}
                {comparisonResult?.document3_detail && (
                  <div className="bg-pink-50 p-4 rounded-lg">
                    <h4 className="font-semibold text-pink-700 mb-2">计划书 3</h4>
                    <p className="text-sm text-gray-700">{comparisonResult.document3_detail.file_name}</p>
                    <p className="text-xs text-gray-600 mt-1">
                      {comparisonResult.document3_detail.insurance_company} - {comparisonResult.document3_detail.insurance_product}
                    </p>
                  </div>
                )}
              </div>
            </div>

            {/* AI生成的对比总结 */}
            <div className="prose max-w-none">
              <div
                dangerouslySetInnerHTML={{ __html: comparisonResult?.comparison_summary || '<p>正在生成对比报告...</p>' }}
              />
            </div>
          </div>
        )}
      </div>
    </div>
  );
}

export default PlanAnalyzer2;
